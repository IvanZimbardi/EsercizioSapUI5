<mvc:View controllerName="testlista.controller.products.ProductsList"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page title="{i18n>lblProducts}">
        <content>
            <Panel class="sapUiResponsiveMargin"
                width="auto">

                <HBox wrap="Wrap"
                    class="sapUiSmallMarginBottom"
                    alignItems="End">
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="{i18n>lblSearchFor}" />
                        <Input width="200px"
                            placeholder="{i18n>plhItemCode}"
                            value="{Filters>/CodArticolo}" />
                    </VBox>

                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="{i18n>lblSearchFor}" />
                        <Input width="200px"
                            placeholder="{i18n>plhItemName}"
                            value="{Filters>/NomeArticolo}" />
                    </VBox>

                    <HBox>
                        <Button text="{i18n>btnSearch}"
                            type="Emphasized"
                            press=".onSearch"
                            class="sapUiTinyMarginEnd" />
                        <Button text="{i18n>btnCancel}"
                            press="._onReset" />
                    </HBox>
                </HBox>

                <Table id="idArticlesTable"
                    items="{Products>/Data}">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{i18n>lblProductsList}" />
                            <ToolbarSpacer/>
                            <Button text="{i18n>btnAdd}"
                                icon="sap-icon://add-product"
                                type="Transparent"
                                press=".onNavToAddProducts" />
                            <Button text="{i18n>btnExport}"
                                icon="sap-icon://excel-attachment"
                                type="Transparent"
                                press=".onExport" />
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column>
                            <Text text="{i18n>lblItemCode}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>lblItemName}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>lblAmount}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>lblQuantitiesAvailable}" />
                        </Column>
                        <Column hAlign="End">
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{Products>CodArticolo}" />
                                <Text text="{Products>NomeArticolo}" />
                                <Text text="{Products>Importo}" />
                                <Text text="{Products>QuantitaDisp}" />
                                <HBox justifyContent="End">
                                    <Button icon="sap-icon://arrow-right"
                                        type="Transparent"
                                        tooltip="{i18n>tlpDetails}"
                                        press=".onNavToEditProducts"/>

                                    <Button icon="sap-icon://delete"
                                        type="Reject"
                                        tooltip="{i18n>tlpDelete}"
                                        press=".onDeleteProducts"/>
                                </HBox>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>
        </content>
    </Page>
</mvc:View>