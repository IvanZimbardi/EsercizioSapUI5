<mvc:View controllerName="testlista.controller.Home"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page"
        title="{i18n>lblOrderManagement}">
        <content>
            <Panel>
                <Table id="idArticlesTable"
                    items="{Products>/}">
                    <headerToolbar>
                        <OverflowToolbar>
                            <Button text="{i18n>btnAdd}"
                                icon="sap-icon://add-product"
                                type="Transparent"/>
                            <Button text="{i18n>btnExport}"
                                icon="sap-icon://excel-attachment"
                                type="Transparent"/>
                            <ToolbarSpacer/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        <Column>
                            <Text text="{i18n>lblItemCode}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>lblItemName}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>lblAmount}" />
                        </Column>
                        <Column>
                            <Text text="{i18n>lblQuantitiesAvailable}" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{CodArticolo}" />
                                <Text text="{NomeArticolo}" />
                                <Text text="{Importo}" />
                                <Text text="{QuantitaDisp}" />
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </Panel>
        </content>
    </Page>
</mvc:View>