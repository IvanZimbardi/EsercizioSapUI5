<mvc:View controllerName="testlista.controller.Products"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m">
    <Page title="{i18n>lblOrderManagement}">
        <content>
            <VBox class="sapUiSmallMargin">
                <HBox alignItems="Center"
                    justifyContent="SpaceBetween"
                    class="sapUiSmallMarginBottom">
                    <Title text="{Mode>/title}"/>
                    <Button icon="sap-icon://nav-back"
                        text="{i18n>lblBackToList}"
                        press=".onNavToHomeProducts" />
                </HBox>

                <f:SimpleForm>
                    <f:content>
                        <Label text="{i18n>lblItemCode}" />
                        <Input enabled="{= !${Mode>/isEdit} }"
                            maxLength="3"
                            type="Number"
                            value="{
                                path: 'Products>/CodArticolo', 
                                type: 'sap.ui.model.type.Integer'
                            }" />

                        <Label text="{i18n>lblItemName}" />
                        <Input maxLength="50"
                            value="{
                                path: 'Products>/NomeArticolo'
                            }" />

                        <Label text="{i18n>lblAmount}" />
                        <Input type="Number"
                            maxLength="4"
                            value="{
                                path:'Products>/Importo',
                                type:'sap.ui.model.type.Integer'
                            }"
                            description="EUR" />

                        <Label text="{i18n>lblQuantitiesAvailable}" />
                        <Input type="Number"
                            maxLength="2"
                            value="{
                                path: 'Products>/QuantitaDisp', 
                                type: 'sap.ui.model.type.Integer'
                            }" />
                    </f:content>
                </f:SimpleForm>

                <HBox justifyContent="End"
                    class="sapUiSmallMarginTop">
                    <Button text="{i18n>btnCancel}"
                        class="sapUiSmallMarginEnd"
                        press=".onCancel"/>
                    <Button text="{i18n>btnSaveProd}"
                        type="Emphasized"
                        press=".onSaveProducts" />
                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>